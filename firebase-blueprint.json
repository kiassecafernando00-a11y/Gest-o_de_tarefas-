{
  "entities": {
    "User": {
      "title": "User",
      "description": "Stores user registration and profile details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "avatarUrl", "updatedAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A workspace that aggregates tasks and members for real-time collaboration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "description", "ownerId", "members", "createdAt", "updatedAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A task entity nested within a project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in_progress", "review", "done"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "dueDate": { "type": "string" },
        "assigneeId": { "type": "string" },
        "tags": { "type": "array" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "projectId", "title", "description", "status", "priority", "createdBy", "createdAt", "updatedAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Real-time thread comment on a concrete task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "taskId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "taskId", "userId", "userName", "userPhoto", "text", "createdAt"]
    },
    "Activity": {
      "title": "Activity",
      "description": "A collaborative real-time workspace activity audit log record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "userName", "userPhoto", "action", "details", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collects user profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Primary collaborative project workspace"
    },
    "/projects/{projectId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks subcollection"
    },
    "/projects/{projectId}/tasks/{taskId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Task discussions"
    },
    "/projects/{projectId}/activities/{activityId}": {
      "schema": "Activity",
      "description": "Activity timeline log"
    }
  }
}
